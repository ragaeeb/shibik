{
  "bin": {
    "shibik": "./dist/cli.js"
  },
  "dependencies": {
    "puppeteer": "^24.5.0"
  },
  "description": "Capture and localize modern websites into static clones with one CLI command.",
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/bun": "^1.3.10",
    "@types/node": "^24.5.2",
    "semantic-release": "^25.0.3",
    "typescript": "~5.9.3"
  },
  "engines": {
    "bun": ">=1.3.10"
  },
  "exports": {
    ".": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "keywords": [
    "cli",
    "clone",
    "crawler",
    "download",
    "puppeteer",
    "static-site",
    "threejs",
    "webgl"
  ],
  "license": "MIT",
  "name": "shibik",
  "packageManager": "bun@1.3.10",
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "private": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json && bun scripts/rewrite-dist-imports.ts",
    "check": "biome lint .",
    "format": "biome check . --write",
    "prepublishOnly": "npm run build",
    "release": "semantic-release",
    "start": "bun run src/cli.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "version": "0.0.0-development"
}
