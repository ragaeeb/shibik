{
    "author": {
        "name": "Ragaeeb Haq",
        "url": "https://github.com/ragaeeb"
    },
    "bin": {
        "shibuk": "dist/cli.js"
    },
    "bugs": {
        "url": "https://github.com/ragaeeb/shibuk/issues"
    },
    "dependencies": {
        "puppeteer": "^24.39.1"
    },
    "description": "Capture and localize modern websites into static clones with one CLI command.",
    "devDependencies": {
        "@biomejs/biome": "^2.4.7",
        "@semantic-release/changelog": "^6.0.3",
        "@semantic-release/commit-analyzer": "^13.0.1",
        "@semantic-release/git": "^10.0.1",
        "@semantic-release/github": "^12.0.6",
        "@semantic-release/npm": "^13.1.5",
        "@semantic-release/release-notes-generator": "^14.1.0",
        "@types/bun": "^1.3.10",
        "@types/node": "^25.5.0",
        "semantic-release": "^25.0.3"
    },
    "engines": {
        "bun": ">=1.3.10"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE.md"
    ],
    "homepage": "https://github.com/ragaeeb/shibuk#readme",
    "keywords": [
        "cli",
        "clone",
        "crawler",
        "download",
        "puppeteer",
        "static-site",
        "threejs",
        "webgl"
    ],
    "license": "MIT",
    "name": "shibuk",
    "packageManager": "bun@1.3.10",
    "private": false,
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ragaeeb/shibuk.git"
    },
    "scripts": {
        "build": "bun scripts/build-dist.ts",
        "check": "biome lint .",
        "format": "biome check . --write",
        "prepublishOnly": "npm run build",
        "start": "bun run src/cli.ts",
        "typecheck": "tsc --noEmit"
    },
    "type": "module",
    "version": "1.0.2"
}
